# kvlang 语法 (BNF)

> 锚定于 kvlang-deep-dive（根设计文档）——每次 deep-dive 更新后需验证本文与实现一致。
> 验证：`python3 tutorial/test.py && python3 tutorial/error_test.py`
> 恢复于 2026-07-19（git: a5a37eb），重写以对齐当前实现（fix-005/009/010/011/015/020/021/025/026/031）。

## 词法

```
digit   = "0" … "9"
letter  = "a" … "z" | "A" … "Z" | "_"
ident   = letter { letter | digit }
integer = digit { digit }
float   = integer [ "." integer ] [ ("e" | "E") [ "+" | "-" ] integer ]
path    = "/" { ident | integer | "[" integer "," integer "]" } [ "." ident ]
string  = '"' { char } '"' | "'" { char } "'" | "`" { char } "`"
comment = "#" { char } newline
```

## 程序结构

```
program     = [ init_block ] { top_level_stmt | function }
              (* 无 import 关键字——lib 树即全局命名空间，跨 lib 调用走全路径 /lib/{lib}.{func}() *)

init_block  = "init" "{" { statement } "}"

top_level_stmt = instruction | function_call
               (* 顶层无嵌套控制流; if/while/for 必须在 def 内 *)

function    = "def" ident "(" [ param_list ] ")" [ "->" "(" [ param_list ] ")" ]
              "{" { statement } "}"

param_list  = param { "," param }
param       = ident [ ":" ident ]      (* type annotation 可选 *)

statement   = instruction | if_stmt | while_stmt | for_stmt | block_stmt
```

## 指令

```
instruction = [ writes "=" ] expr
            | [ writes "<-" ] expr
            | expr [ "->" writes ]
            | expr                     (* 纯副作用调用 *)

writes      = write_slot { "," write_slot }
write_slot  = ident                    (* 裸名：帧内变量 *)
            | path                     (* 绝对路径 / 成员：/a/b  /a.b *)
            | ident "." ident          (* 成员写：base.field *)
            | ident "." "*" ident      (* 动态键写：base.*key, fix-015 *)
            | ident "[" expr "]"       (* 下标写：arr[idx] *)
```

## 表达式

```
expr        = primary { infix_primary }
            | prefix_unary primary

primary     = literal | ident | path | ident "." ident | ident "." "*" ident
            | ident "[" expr "]"       (* 下标读 *)
            | "(" expr ")"             (* 分组 *)
            | ident "(" [ arg_list ] ")"  (* 函数调用 *)
            | dict_literal
            | array_literal

prefix_unary = "-" | "!"

infix_primary = binary_op expr

binary_op  = "+" | "-" | "*" | "/" | "%" | "==" | "!=" | "<" | ">" | "<=" | ">="
           | "&&" | "||" | "&" | "|" | "^" | "<<" | ">>"

arg_list    = expr { "," expr }

literal     = integer | float | string | "null" | "true" | "false"

array_literal = "[" [ expr { "," expr } ] "]"         (* [1,2,3] → array(1,2,3) *)

dict_literal = "{" [ dict_entry { (";" | newline) dict_entry } ] "}"
dict_entry   = ident "=" expr                          (* { k=v; k2=v2 } *)
```

## 控制流（仅限 def 体内）

```
if_stmt     = "if" "(" expr ")" "{" { statement } "}"
              [ "else" "{" { statement } "}" ]

while_stmt  = "while" "(" expr ")" "{" { statement } "}"

for_stmt    = "for" "(" ident "in" ident ")" "{" { statement } "}"
              (* for (x in arr) — arr 为键族/数组 *)

block_stmt  = ident ":" "{" { statement } "}"         (* label: { ... } *)
```

## 内建函数（部分）

```
builtin_call = ("abs" | "neg" | "sign" | "pow" | "sqrt" | "exp" | "log"
              | "min" | "max" | "print" | "cerr" | "input"
              | "int" | "float" | "bool"
              | "int8" | "int16" | "int32" | "int64"
              | "uint8" | "uint16" | "uint32" | "uint64"
              | "float32" | "float64"
              | "char" | "ord" | "strlen" | "strcmp" | "strstr"
              | "slice" | "concat"
              | "array" | "len" | "at" | "set" | "has" | "sort"
              | "dict" | "kvat" | "kvhas"
              | "debugger") "(" [ arg_list ] ")"

(* min/max 支持变参: min(a,b,c,...), fix-026 *)
(* debugger(): 内联暂停, 非调试模式 no-op, fix-031 *)
(* / : 两侧 int → 整除(C 风格); 任一侧 float → 浮除, fix-020 *)
(* s[i] 读返单字符字符串, 越界返 ""; s[i]="X" 单字符替换写回新串, fix-025 *)
(* + 作用在 string∧string → 拼接, fix-025 *)
```
